# Tailscale Auth Keys
TS_AUTHKEY_GATEWAY=tskey-auth-xxxx
TS_AUTHKEY_OPENCLAW=tskey-xxxxx

# Ports
BACKEND_PORT=8000
GATEWAY_PORT=8080

# OpenClaw Configuration
OPENCLAW_HOSTNAME=openclaw-production
OPENCLAW_PORT=8001
OPENCLAW_IP=100.x.x.x
OPENCLAW_EMAIL=admin@localhost
OPENCLAW_PASSWORD=admin

# Performance Tuning
MAX_CONNECTIONS=50
MAX_KEEPALIVE_CONNECTIONS=20
TOKEN_REFRESH_INTERVAL=3300  # 55 minutes

# WebSocket
WS_HEARTBEAT_INTERVAL=30  # seconds

# JWT (These should be same as backend)
JWT_ALGORITHM="your cryptographic algorithm"
JWT_SIGNING_KEY= "XXXooOOxOOX"
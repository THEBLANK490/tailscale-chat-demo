{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Gateway",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "gateway.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8080",
        "--reload"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/gateway"
      },
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}